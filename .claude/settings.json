  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/report-gcp/scripts/hook-gcloud-literal-guard.sh"
          }
        ]
