{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Agent",
      "Bash(bash .claude/skills/report-gcp/scripts/scan.sh:*)",
      "Bash(.claude/skills/report-gcp/scripts/scan.sh:*)",
      "Bash(bash .claude/skills/report-gcp/scripts/digest.sh:*)",
      "Bash(bash .claude/skills/report-gcp/scripts/check-links.sh:*)",
      "Bash(bash .claude/skills/report-gcp/scripts/archive-report.sh:*)",
      "Bash(python3 .claude/skills/report-gcp/scripts/network-facts.py:*)",
      "Bash(node .claude/skills/report-gcp/scripts/build-report.js:*)",
      "Bash(gcloud auth list:*)",
      "Bash(gcloud config list:*)",
      "Bash(gcloud config get-value:*)",
      "Bash(gcloud projects describe:*)",
      "Bash(gcloud projects get-iam-policy:*)",
      "Bash(gcloud * list:*)",
      "Bash(gcloud * describe:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(mkdir:*)",
      "Bash(python3:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(date:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(printf:*)",
      "Bash(echo:*)",
      "Bash(xargs:*)",
      "Bash(column:*)",
      "Bash(bc:*)"
    ],
    "deny": [
      "Bash(gcloud * create*)",
      "Bash(gcloud * delete*)",
      "Bash(gcloud * update*)",
      "Bash(gcloud * patch*)",
      "Bash(gcloud * set-*)",
      "Bash(gcloud * add-*)",
      "Bash(gcloud * remove-*)",
      "Bash(gcloud * enable*)",
      "Bash(gcloud * disable*)",
      "Bash(gcloud * deploy*)",
      "Bash(gcloud * import*)",
      "Bash(gcloud * export*)",
      "Bash(gcloud * apply*)",
      "Bash(gcloud * attach*)",
      "Bash(gcloud * detach*)",
      "Bash(gcloud * start*)",
      "Bash(gcloud * stop*)",
      "Bash(gcloud * restart*)",
      "Bash(gcloud * reset*)",
      "Bash(gcloud * restore*)",
      "Bash(gcloud * migrate*)",
      "Bash(gcloud * move*)",
      "Bash(gcloud * clone*)",
      "Bash(gcloud * resize*)",
      "Bash(gcloud * ssh:*)",
      "Bash(gcloud * scp:*)",
      "Bash(gcloud config set:*)",
      "Bash(gcloud services enable:*)",
      "Bash(gcloud services disable:*)",
      "Bash(gsutil rm:*)",
      "Bash(gsutil cp:*)",
      "Bash(gsutil mv:*)",
      "Bash(gsutil rsync:*)",
      "Bash(gsutil mb:*)",
      "Bash(gsutil rb:*)",
      "Bash(gsutil acl:*)",
      "Bash(gsutil iam:*)",
      "Bash(gcloud storage rm:*)",
      "Bash(gcloud storage cp:*)",
      "Bash(gcloud storage mv:*)",
      "Bash(gcloud storage rsync:*)",
      "Bash(bq rm:*)",
      "Bash(bq mk:*)",
      "Bash(bq cp:*)",
      "Bash(bq load:*)",
      "Bash(bq insert:*)",
      "Bash(bq update:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)"
